# --- Firebase (client; Vite exposes VITE_* to the browser) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Gemini (server-side ONLY — never use VITE_ for this key) ---
# Local: used by Express when you run `npm run backend`.
# Netlify: set GEMINI_API_KEY in Site configuration → Environment variables (not in the repo).
GEMINI_API_KEY=

# Optional override if Google changes model ids (default: gemini-1.5-flash).
# GEMINI_MODEL=gemini-1.5-flash

# Comma-separated browser origins allowed to call /api (Express + Netlify function CORS).
# Example Netlify: https://your-site.netlify.app
ALLOWED_ORIGINS=http://localhost:5173

# Optional: allow requests without a matching Origin if header x-api-key matches.
PUBLIC_API_KEY=
