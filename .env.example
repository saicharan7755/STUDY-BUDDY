# --- Firebase (client; Vite exposes VITE_* to the browser) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Gemini (server-side ONLY — never use VITE_ for this key) ---
# Local: used by Express when you run `npm run backend`.
# Vercel: set GEMINI_API_KEY in Vercel project Settings → Environment Variables.
GEMINI_API_KEY=

# Optional override if Google changes model ids (default: gemini-1.5-flash).
# GEMINI_MODEL=gemini-1.5-flash

# Comma-separated browser origins allowed to call /api.
# Local development: http://localhost:5173
# Vercel production: https://yourdomain.vercel.app or https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# Public canonical site URL used by React Helmet SEO tags.
VITE_SITE_URL=http://localhost:5173

# Optional: allow requests without a matching Origin if header x-api-key matches.
PUBLIC_API_KEY=

# --- Authentication (Vercel deployment) ---
# These are used by the /api/auth-* functions.
# Set these in Vercel project Settings → Environment Variables.
JWT_SECRET=your_jwt_secret_key_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here
DEMO_USER_EMAIL=user@example.com
DEMO_USER_PASSWORD=password123

