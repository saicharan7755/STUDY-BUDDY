{
  "name": "vibecode",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "node server.js",
    "build": "npm run clean && vite build",
    "build:prod": "npm run lint && npm run format:check && npm run clean && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "start": "serve -s dist -l tcp:$PORT",
    "clean": "rimraf dist .storybook/static coverage",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "firebase": "^12.12.1",
    "framer-motion": "^12.38.0",
    "helmet": "^7.2.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "serve": "^14.2.6",
    "tailwind-merge": "^3.5.0"
